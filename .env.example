# DiracData local development settings.
#
# Copy this file to `.env` and fill credentials locally:
#   cp .env.example .env

DIRACDATA_MODE=dev

# Scoped customer/query environment.
DIRACDATA_CATALOG=retail_pod
DIRACDATA_DATABASE=analytics
DIRACDATA_SCHEMA=retail_analytics
DIRACDATA_SQL_DIALECT=duckdb

# v2 local runtime paths.
DIRACDATA_V2_DATA_ROOT=v2/data
DIRACDATA_V2_METADATA_DESCRIPTIONS_PATH=v2/context/retail_analytics_metadata_descriptions.json
DIRACDATA_V2_SCHEMA_AST_PATH=v2/learning/artifacts/retail_analytics_v2_20260610/schema_ast.json
DIRACDATA_V2_SQL_LIBRARY_PATH=v2/learning/artifacts/retail_analytics_patterns_v2_20260610/sql_library.json
DIRACDATA_V2_SEMANTIC_CATALOG_PATH=v2/learning/artifacts/retail_analytics_semantic_catalog_v2_20260611/semantic_catalog.json

# Agent runtime.
DIRACDATA_AGENT_MODEL_PROFILE=anthropic_haiku_45
DIRACDATA_AGENT_LLM_MAX_TOKENS=8192
DIRACDATA_AGENT_LLM_TEMPERATURE=0
DIRACDATA_AGENT_SQL_MAX_ROWS=100
DIRACDATA_AGENT_COLUMN_VALUES_MAX_VALUES=100
DIRACDATA_PRIMITIVE_MAX_ITERATIONS=10
DIRACDATA_PRIMITIVE_SUBAGENT_MAX_ITERATIONS=10
DIRACDATA_PRIMITIVE_MAX_TOOL_RESULT_CHARS=12000

# Model/provider credentials. Keep real values out of Git.
DIRACDATA_ANTHROPIC_API_KEY=
DIRACDATA_ANTHROPIC_BASE_URL=https://api.anthropic.com
DIRACDATA_OPENAI_API_KEY=
DIRACDATA_GOOGLE_API_KEY=
DIRACDATA_BEDROCK_API_KEY=
DIRACDATA_BEDROCK_REGION=ap-south-1
DIRACDATA_AWS_REGION=us-east-1

# Optional object/lake storage for generated artifacts and local MinIO.
DIRACDATA_OBJECT_STORE=s3
DIRACDATA_ARTIFACT_BUCKET=diracdata
DIRACDATA_LAKE_BUCKET=lake
DIRACDATA_S3_ENDPOINT_URL=http://localhost:9000
DIRACDATA_AWS_ACCESS_KEY_ID=minioadmin
DIRACDATA_AWS_SECRET_ACCESS_KEY=minioadmin
