# DiracData local development settings.
#
# Copy to `.env` for local use:
#   cp .env.example .env

DIRACDATA_MODE=dev

# Customer-facing query environment.
DIRACDATA_QUERY_ENGINE=duckdb
DIRACDATA_SQL_DIALECT=duckdb
DIRACDATA_CATALOG=commerce_pod
DIRACDATA_DATABASE=analytics
DIRACDATA_SCHEMA=main
DIRACDATA_CATALOG_CONFIG=conf/catalogs/commerce_pod.minio.json
DIRACDATA_DUCKDB_DATABASE=:memory:

# Learning runtime limits.
DIRACDATA_LEARNING_SAMPLE_LIMIT=1000
DIRACDATA_LEARNING_DISTINCT_LIMIT=1000
DIRACDATA_LEARNING_TOP_VALUES_LIMIT=20
DIRACDATA_LEARNING_CONTEXT_DISTINCT_VALUES_LIMIT=50
DIRACDATA_LEARNING_DESCRIPTION_COLUMN_BATCH_SIZE=50
DIRACDATA_LEARNING_ARTIFACT_STRATEGY=deterministic
DIRACDATA_LEARNING_CONTEXT_MODE=linear
DIRACDATA_LEARNING_AGENTIC_QUERY_HISTORY_LIMIT=80
DIRACDATA_LEARNING_AGENTIC_MAX_COLUMNS=500
DIRACDATA_LEARNING_AGENTIC_REPAIR_ATTEMPTS=2
DIRACDATA_LEARNING_EMBEDDING_PROVIDER=none
DIRACDATA_LEARNING_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
DIRACDATA_LEARNING_EMBEDDING_LOCAL_FILES_ONLY=false
DIRACDATA_LEARNING_VECTOR_INDEX_BACKEND=faiss
DIRACDATA_LEARNING_VECTOR_INDEX_ALGORITHM=hnsw_flat
DIRACDATA_LEARNING_VECTOR_INDEX_METRIC=inner_product
DIRACDATA_LEARNING_FAISS_HNSW_M=32
DIRACDATA_LEARNING_FAISS_EF_CONSTRUCTION=200
DIRACDATA_LEARNING_BM25_K1=1.2
DIRACDATA_LEARNING_BM25_B=0.75
DIRACDATA_LEARNING_BM25_DELTA=1.0
DIRACDATA_LEARNING_RRF_K=60
DIRACDATA_LEARNING_RUN_ID=dev_learning_run

# Join discovery runtime.
DIRACDATA_JOIN_HISTORY_LLM_BATCH_SIZE=50
DIRACDATA_JOIN_NAME_SIMILARITY_MIN=0.55
DIRACDATA_JOIN_VALUE_OVERLAP_MIN=0.05
DIRACDATA_JOIN_MIN_SCORE=0.45
DIRACDATA_JOIN_SAMPLE_MATCH_MIN=1
DIRACDATA_JOIN_KEY_UNIQUE_TOLERANCE=0.02

# Learning description model. Provider-specific credentials stay outside repo.
# Prefer Bedrock profiles for shared/cloud learning runs, e.g.
# DIRACDATA_LLM_MODEL_PROFILE=bedrock_anthropic_sonnet_46_ap_south_1
DIRACDATA_LLM_MODEL_PROFILE=
DIRACDATA_LLM_PROVIDER=anthropic
DIRACDATA_LLM_MODEL=claude-sonnet-4-6
DIRACDATA_LLM_MAX_TOKENS=8192
DIRACDATA_LLM_TEMPERATURE=0
DIRACDATA_ANTHROPIC_BASE_URL=https://api.anthropic.com
DIRACDATA_ANTHROPIC_API_KEY=
DIRACDATA_GOOGLE_API_KEY=
DIRACDATA_OPENAI_API_KEY=

# Data analyst agent runtime. Empty model values inherit DIRACDATA_LLM_* defaults.
DIRACDATA_AGENT_MODEL_PROFILE=
DIRACDATA_AGENT_LLM_PROVIDER=anthropic
DIRACDATA_AGENT_LLM_MODEL=claude-sonnet-4-6
DIRACDATA_AGENT_LLM_MAX_TOKENS=8192
DIRACDATA_AGENT_LLM_TEMPERATURE=0
DIRACDATA_AGENT_STREAMING=off
DIRACDATA_AGENT_STREAM_MODES=updates,messages
DIRACDATA_AGENT_STREAM_VERSION=v2
DIRACDATA_AGENT_CHECKPOINTER=memory
DIRACDATA_AGENT_STORE=memory
DIRACDATA_AGENT_SCHEMA_SEARCH_LIMIT=10
DIRACDATA_AGENT_INLINE_SCHEMA_CONTEXT=false
DIRACDATA_AGENT_BUSINESS_SEARCH_LIMIT=10
DIRACDATA_AGENT_CONTEXT_CONTRACT_ENABLED=true
DIRACDATA_AGENT_CONTEXT_CONTRACT_PATTERN_LIMIT=2
DIRACDATA_AGENT_CONTEXT_CONTRACT_INVARIANT_LIMIT=6
DIRACDATA_AGENT_CANDIDATE_SEARCH_ENABLED=true
DIRACDATA_AGENT_CANDIDATE_SEARCH_LLM_ENABLED=false
DIRACDATA_AGENT_CANDIDATE_SEARCH_LIMIT=20
DIRACDATA_AGENT_CANDIDATE_SEARCH_PER_QUERY_LIMIT=30
DIRACDATA_AGENT_CANDIDATE_SEARCH_MAX_QUERIES=12
DIRACDATA_AGENT_CANDIDATE_SEARCH_MODEL_PROFILE=
DIRACDATA_AGENT_CANDIDATE_SEARCH_LLM_PROVIDER=
DIRACDATA_AGENT_CANDIDATE_SEARCH_LLM_MODEL=
DIRACDATA_AGENT_CANDIDATE_SEARCH_LLM_MAX_TOKENS=2048
DIRACDATA_AGENT_CANDIDATE_SEARCH_LLM_TEMPERATURE=0
DIRACDATA_AGENT_PROFILE_VALUES_LIMIT=25
DIRACDATA_AGENT_JOIN_RECOVERY_ENABLED=true
DIRACDATA_AGENT_JOIN_RECOVERY_CANDIDATE_LIMIT=50
DIRACDATA_AGENT_SQL_MAX_ROWS=100
DIRACDATA_AGENT_SQL_TIMEOUT_SECONDS=30
DIRACDATA_AGENT_COMPILER_MAX_PROBES=6
DIRACDATA_AGENT_COMPILER_PROBE_MAX_ROWS=20
DIRACDATA_AGENT_COMPILER_MAX_REPAIRS=1
DIRACDATA_AGENT_REFLECTION_ENABLED=false
DIRACDATA_AGENT_REFLECTION_MODEL_PROFILE=
DIRACDATA_AGENT_REFLECTION_LLM_PROVIDER=
DIRACDATA_AGENT_REFLECTION_LLM_MODEL=
DIRACDATA_AGENT_REFLECTION_LLM_MAX_TOKENS=2048
DIRACDATA_AGENT_REFLECTION_LLM_TEMPERATURE=0
DIRACDATA_AGENT_REFLECTION_MAX_RETRIES=1

# Object store used for DiracData artifacts such as learned contexts,
# table profiles, samples, query traces, and evaluation outputs.
DIRACDATA_OBJECT_STORE=s3
DIRACDATA_ARTIFACT_BUCKET=diracdata

# Optional source-data lake bucket. Keep source data separate from artifacts.
DIRACDATA_LAKE_BUCKET=lake

# MinIO-compatible S3 settings for dev.
DIRACDATA_S3_ENDPOINT_URL=http://localhost:9000
DIRACDATA_AWS_REGION=us-east-1
DIRACDATA_BEDROCK_REGION=
DIRACDATA_BEDROCK_API_KEY=
DIRACDATA_AWS_ACCESS_KEY_ID=minioadmin
DIRACDATA_AWS_SECRET_ACCESS_KEY=minioadmin

# Local fallback artifact root for tests and no-S3 development.
DIRACDATA_LOCAL_ARTIFACT_ROOT=.diracdata/artifacts
